      where
        (#3 group)
        (#4 group)
    #pragma diagram {"xy":"H19813;V1900"} #end)
    (#5 expr #6 / #7
      where
        (#6 group)
        (#7 group)
    #pragma diagram {"xy":"H39813;V5600"} #end)
    (#8 expr 32.0
    #pragma diagram {"xy":"H6500;V3800"} #end)
    (#9 expr 1.8
    #pragma diagram {"xy":"H20813;V7500"} #end)
    
    (#10 wire #8 => #4)
    (#11 wire #0 => #3)
    (#12 wire #2 => #6
    #pragma diagram {"wp":"#2 h6500 v1800 #6"} #end)
    (#13 wire #9 => #7)
    (#14 wire #5 => #1)
}

function ToFahrenheit (tempC: float32;)
  returns (tempF: float32;)
{
  diagram
    (#0 def tempF
    #pragma diagram {"xy":"H-7338;V0","wh":"10000;3200"} #end)
    (#1 expr tempC
    #pragma diagram {"xy":"H-52914;V-1800","wh":"10000;3200"} #end)
