    (#3 expr #4 * #5
      where
        (#4 group)
        (#5 group)
    #pragma diagram {"xy":"H-39813;V-3700"} #end)
    (#6 expr #7 + #8
      where
        (#7 group)
        (#8 group)
    #pragma diagram {"xy":"H-19813;V0"} #end)
    (#9 expr 32.0
    #pragma diagram {"xy":"H-38813;V1900"} #end)
    
    (#10 wire #2 => #4)
    (#11 wire #1 => #5)
    (#12 wire #3 => #7
    #pragma diagram {"wp":"#3 h6500 v1800 #7"} #end)
