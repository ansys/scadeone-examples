function ToCelsius (tempF: float32;)
  returns (tempC: float32;)
{
  diagram
    (#0 expr tempF
    #pragma diagram {"xy":"H6687;V0","wh":"10000;3200"} #end)
    (#1 def tempC
    #pragma diagram {"xy":"H53313;V5600","wh":"10000;3200"} #end)
