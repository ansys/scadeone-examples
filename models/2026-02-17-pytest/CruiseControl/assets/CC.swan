node CruiseSpeedMgt (set: bool;
                     quickAccel: bool;
                     quickDecel: bool;
                     speed: Defs::Speed;)
  returns (cruiseSpeed: Defs::Speed last = speed;)
{
  diagram
    (#0 def cruiseSpeed
    #pragma diagram {"xy":"H61948;V12925","wh":"16000;3200"} #end)
    (#1 block (pwlinear::LimiterUnSymmetrical \ lowLimit: Defs::SPEED_MIN, highLimit: Defs::SPEED_MAX)
              #pragma diagram {"xy":"H33448;V12925","wh":"27250;17720"} #end)
    (#2 expr localCruiseSpeed
    #pragma diagram {"xy":"H2948;V12925","wh":"20000;3200"} #end)
    
    (#3 wire #1 .(output) => #0
    #pragma diagram {"wp":"v0|#1 #0"} #end)
    (#4 wire #2 => #1 .(input))
    
    (var
        localCruiseSpeed: Defs::Speed;)
    (activate $IfBlock1
      if set
      then
        {
          diagram
            (#5 def localCruiseSpeed
            #pragma diagram {"xy":"h25000;v0","wh":"20000;3200"} #end)
            (#6 expr speed
            #pragma diagram {"xy":"h-20000;v0","wh":"10000;3200"} #end)
            
            (#7 wire #6 => #5)
        #pragma diagram {"xy":"h0;v-19300","wh":"74000;7200"} #end
        }
      elsif quickAccel
      then
        {
          diagram
            (#8 expr Defs::SPEED_INC
            #pragma diagram {"xy":"h-25000;v1900","wh":"20000;3200"} #end)
            (#9 def localCruiseSpeed
            #pragma diagram {"xy":"h25000;v0","wh":"20000;3200"} #end)
            (#10 expr #11 + #12
              where
                (#11 group)
                (#12 group)
            #pragma diagram {"xy":"h0;v0"} #end)
            (#13 expr last 'cruiseSpeed
            #pragma diagram {"xy":"h-25000;v-1900","wh":"20000;3200"} #end)
            
            (#14 wire #13 => #11)
            (#15 wire #8 => #12)
            (#16 wire #10 => #9)
        #pragma diagram {"xy":"h0;v-6000","wh":"74000;11000"} #end
        }
      elsif quickDecel
      then
        {
          diagram
            (#17 expr Defs::SPEED_INC
            #pragma diagram {"xy":"h-25000;v1900","wh":"20000;3200"} #end)
            (#18 def localCruiseSpeed
            #pragma diagram {"xy":"h25000;v0","wh":"20000;3200"} #end)
            (#19 expr #20 - #21
              where
                (#20 group)
                (#21 group)
            #pragma diagram {"xy":"h0;v0"} #end)
            (#22 expr last 'cruiseSpeed
            #pragma diagram {"xy":"h-25000;v-1900","wh":"20000;3200"} #end)
            
            (#23 wire #22 => #20)
            (#24 wire #19 => #18)
            (#25 wire #17 => #21)
        #pragma diagram {"xy":"h0;v9200","wh":"74000;11000"} #end
        }
      else
        {
          diagram
            (#26 def localCruiseSpeed
            #pragma diagram {"xy":"h25000;v0","wh":"20000;3200"} #end)
