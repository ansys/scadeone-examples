                (#12 def throttleCmd
                #pragma diagram {"xy":"h40900;v-2250","wh":"16000;3200"} #end)
                (#13 expr speed
                #pragma diagram {"xy":"h-37900;v-5750","wh":"10000;3200"} #end)
                (#14 block CruiseRegulation
                           #pragma diagram {"xy":"h0;v-2250","wh":"20000;14000"} #end)
                
                (#15 wire #14 .(throttleCmd) => #12
                #pragma diagram {"wp":"v0|#14 #12"} #end)
                (#16 wire #10 => #14 .(cruiseSpeed))
                (#17 wire #9 => #11)
                (#18 wire #13 => #14 .(speed))
            state #26 StandBy
            #pragma diagram {"xy":"h58950;v2375","wh":"50000;15600"} #end :
              diagram
                (#20 expr accel
                #pragma diagram {"xy":"h-10000;v2200","wh":"10000;3200"} #end)
                (#21 def throttleCmd
                #pragma diagram {"xy":"h13000;v2200","wh":"16000;3200"} #end)
                (#22 expr Defs::STDBY
                #pragma diagram {"xy":"h-13000;v-2200","wh":"16000;3200"} #end)
                (#23 def cruiseState
                #pragma diagram {"xy":"h13000;v-2200","wh":"16000;3200"} #end)
                
                (#24 wire #22 => #23)
                (#25 wire #20 => #21)
            :1: #19 unless if (stdbyCondition)
            restart #26
            #pragma diagram {"tp":"h52900;v0|#19 h4033 h4033 h-25000;v0|#26"} #end;
            :1: #26 unless if (not stdbyCondition)
            restart #19
            #pragma diagram {"tp":"h0;v-7800|#26 v-500 v-500 v-500 v-4350 h-8700;v-4350 h-8700 h-22367 h-22367 h-22367 h-2750 h-2750;v1375 v1375 v667 v667 h0;v-13250|#19"} #end;
            #pragma diagram {"xy":"h0;v-9188","wh":"175900;39250"} #end)
      state #34 Interrupt
