          #pragma diagram {"xy":"h-28800;v21812","wh":"26000;3200"} #end)
          
          (#5 wire #1 => #3 .(2))
          (#6 wire #2 => #3 .(1))
          (#7 wire #4 => #3 .(3))
          (#8 wire #3 .(1) => #0
          #pragma diagram {"wp":"v0|#3 #0"} #end)
          
          (var
              stdbyCondition: bool;)
          (automaton $SM3
            initial state #19 On
            #pragma diagram {"xy":"h-31050;v2375","wh":"105800;26500"} #end :
              diagram
                (#9 expr Defs::ON
                #pragma diagram {"xy":"h-11900;v9012","wh":"12000;3200"} #end)
                (#10 expr cruiseSpeed
                #pragma diagram {"xy":"h-40900;v1250","wh":"16000;3200"} #end)
                (#11 def cruiseState
