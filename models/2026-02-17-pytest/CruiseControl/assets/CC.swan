node RegulationMgt (resume_: bool;
                    brake: Defs::Percent;
                    accel: Defs::Percent;
                    speed: Defs::Speed;
                    cruiseSpeed: Defs::Speed;)
  returns (cruiseState: Defs::CruiseState;
           throttleCmd: Defs::Percent;)
{
  diagram
    (automaton $Regulation
      initial state #27 Active
      #pragma diagram {"xy":"h-29025;v2344","wh":"183900;65625"} #end :
        diagram
          (#0 def stdbyCondition
          #pragma diagram {"xy":"h41000;v21812","wh":"18000;3200"} #end)
          (#1 expr speed < Defs::SPEED_MIN
          #pragma diagram {"xy":"h-28800;v26479","wh":"26000;3200"} #end)
          (#2 expr accel > Defs::PEDALS_MIN
          #pragma diagram {"xy":"h-29800;v17146","wh":"28000;3200"} #end)
